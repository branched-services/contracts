# Infrared Contracts Deployment Configuration
# Copy to .env and fill in values: cp .env.example .env

# --- Wallet Configuration ---

# Wallet type: trezor, ledger, or privatekey
# Auto-detected from PRIVATE_KEY if not set
WALLET_TYPE=trezor

# Required for trezor/ledger: your hardware wallet's Ethereum address
DEPLOYER_ADDRESS=

# Required for privatekey mode only (CI, testing)
# PRIVATE_KEY=

# HD derivation path (optional, default: m/44'/60'/0'/0/0)
# HD_PATH=m/44'/60'/0'/0/0

# --- Ownership ---

# Gnosis Safe multisig address
# Required for mainnet deployments, optional for testnet
SAFE_ADDRESS=

# --- RPC URLs ---

ETH_RPC_URL=
BASE_RPC_URL=
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# --- Block Explorer API Keys ---

ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# --- Optional ---

# Salt version for CREATE3 deterministic addresses (default: v1)
# SALT_VERSION=v1
