# Infrared Contracts Deployment Configuration                                                                                                               
# Copy to .env and fill in values: cp .env.example .env                                                                                                     
                                                                                                                                                            
# --- Wallet Configuration ---                                                                                                                              
#                                                                                                                                                           
# Deploys use a Foundry-encrypted keystore. Create one with:    
#   ./setup-deployer-wallet.sh infrared-deployer                                                                                                            
# Foundry prompts for the password at broadcast time; the plaintext key                                                                                     
# never touches disk.                                                                                                                                       
                                                                                                                                                            
# Account name passed to setup-deployer-wallet.sh (matches the filename                                                                                     
# in ~/.foundry/keystores/).                                    
KEYSTORE_ACCOUNT=infrared-deployer                                                                                                                          
                                                                                                                                                            
# Deployer's Ethereum address (printed by setup-deployer-wallet.sh).                                                                                        
DEPLOYER_ADDRESS=                                                                                                                                           
                                                                                                                                                            
# --- Ownership ---
                                                                                                                                                            
# Gnosis Safe multisig address.                                                                                                                             
# Required for mainnet, optional for testnet.
SAFE_ADDRESS=                                                                                                                                               
                                                                                                                                                            
# Router contract owner. Defaults to SAFE_ADDRESS if set, else DEPLOYER_ADDRESS.                                                                            
# ROUTER_OWNER=                                                                                                                                             
                                                                                                                                                            
# Router liquidator. Authorized to call transferRouterFunds /                                                                                               
# swapRouterFunds even while the Router is paused. Should be a dedicated
# hot wallet, distinct from ROUTER_OWNER and from the deployer.                                                                                             
# Create one with: ./setup-deployer-wallet.sh infrared-liquidator                                                                                           
# ROUTER_LIQUIDATOR=                                                                                                                                        
                                                                                                                                                            
# --- RPC URLs ---                                              
                                                                                                                                                            
ETH_RPC_URL=                                                                                                                                                
BASE_RPC_URL=
SEPOLIA_RPC_URL=                                                                                                                                            
BASE_SEPOLIA_RPC_URL=                                           
                                                                                                                                                            
# --- Block Explorer API Keys ---
                                                                                                                                                            
# Etherscan V2 key -- single key works across all supported chains.                                                                                         
ETHERSCAN_API_KEY=
                                                                                                                                                            
# --- Optional ---                                              
                                                                                                                                                            
# Salt version for CREATE3 deterministic addresses (default: v1).                                                                                           
# SALT_VERSION=v1